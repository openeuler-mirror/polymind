# 服务配置
SERVER_PORT=3000
SERVER_DOMAIN=localhost

# 后端API配置
NEXT_PUBLIC_AGENTD_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:18080

# 部署路径配置
INSTALL_DIR=/opt/polymind-web
NGINX_CONF_DIR=/etc/nginx/conf.d

# 进程配置
PM2_PROCESS_NAME=polymind-web
PM2_INSTANCES=max

# Nginx配置
SKIP_NGINX=true # 是否跳过Nginx配置，设为true则不需要安装Nginx
