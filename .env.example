# API Configuration
NEXT_PUBLIC_AGENTD_API_URL=https://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:18080
NEXT_PUBLIC_API_TIMEOUT=30000

# Retry and Reconnection Configuration
NEXT_PUBLIC_MAX_RETRY_ATTEMPTS=3
NEXT_PUBLIC_RECONNECT_INTERVAL=3000
NEXT_PUBLIC_MAX_RECONNECT_ATTEMPTS=5

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key

# Other Configuration
NODE_ENV=development